:80 {
	handle /socket.io/* {
		reverse_proxy {
			dynamic a {
				name tasks.backend
				port 3001
				refresh 5s
			}
		}
	}

	@probes path /healthz /stats
	handle @probes {
		reverse_proxy {
			dynamic a {
				name tasks.backend
				port 3001
				refresh 5s
			}
		}
	}

	handle {
		root * /srv
		try_files {path} /index.html
		file_server
	}
}
