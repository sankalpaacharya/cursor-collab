{
  "name": "live-cursors",
  "version": "1.0.0",
  "private": true,
  "description": "Real-time shared-workspace cursor tracking (Express + Socket.IO + Redis, React + Vite, TypeScript)",
  "scripts": {
    "dev": "bash scripts/dev.sh",
    "dev:docker": "bash scripts/dev.sh --docker",
    "dev:server": "pnpm --filter cursor-server dev",
    "dev:client": "pnpm --filter cursor-client dev",
    "build:client": "pnpm --filter cursor-client build",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm --filter cursor-server test",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:demo": "DEMO=1 playwright test demo.spec.ts --headed",
    "test:e2e:install": "playwright install chromium",
    "loadtest": "pnpm --filter cursor-server loadtest"
  },
  "engines": {
    "node": ">=22",
    "pnpm": ">=8"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^22.20.0",
    "mprocs": "^0.9.6"
  }
}
