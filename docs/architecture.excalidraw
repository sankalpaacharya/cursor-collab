      "width": 300,
      "height": 81.25,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "roundness": null,
      "text": "Stateless replicas.\nKill / restart / upgrade any of them —\nclients auto-reconnect to another and\nre-sync. A TTL sweep clears cursors\nleft by a crashed replica.",
      "fontSize": 13,
      "fontFamily": 1,
      "textAlign": "center",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Stateless replicas.\nKill / restart / upgrade any of them —\nclients auto-reconnect to another and\nre-sync. A TTL sweep clears cursors\nleft by a crashed replica.",
      "lineHeight": 1.25
    },
