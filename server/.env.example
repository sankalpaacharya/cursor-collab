# ---- HTTP / WebSocket listener ----
PORT=3001
HOST=0.0.0.0

# Comma-separated allowed origins, or * for any (dev only).
CORS_ORIGIN=*

# ---- Redis (multi-replica fan-out + shared presence) ----
# Set REDIS_ENABLED=false to run a single in-memory replica with no Redis.
REDIS_ENABLED=true
REDIS_URL=redis://localhost:6379

# Stable id for this replica. Leave unset to auto-generate (hostname + random).
# SERVER_ID=

# ---- Presence / heartbeat tuning (milliseconds) ----
HEARTBEAT_INTERVAL_MS=10000
PRESENCE_TTL_MS=30000
SWEEP_INTERVAL_MS=15000

# ---- Misc ----
LOG_LEVEL=info
NODE_ENV=development
